{
  "buildCommand": "corepack pnpm build",
  "installCommand": "corepack pnpm install",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
